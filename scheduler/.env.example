# ===========================================
# Database
# ===========================================
DATABASE_URL=postgres://user:password@localhost:5432/simplepost?schema=public

# ===========================================
# S3-Compatible Storage (Cloudflare R2, etc.)
# User uploads, presigned URLs, and temp media for publishing
# Browser uploads require bucket CORS for PUT + Content-Type from the exact
# Scheduler origin. S3_STORAGE_BASE_URL must expose objects publicly.
# ===========================================
S3_STORAGE_ACCESS_KEY_ID=your_access_key_id
S3_STORAGE_SECRET_ACCESS_KEY=your_secret_access_key
S3_STORAGE_REGION=auto
S3_STORAGE_BUCKET=simple-post-scheduler
S3_STORAGE_BASE_URL=https://files.yourdomain.com
S3_STORAGE_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ===========================================
# Email (Resend)
# ===========================================
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_ADDRESS="SimplePost <auth@yourdomain.com>"

# ===========================================
# Authentication (Better Auth)
# ===========================================
BETTER_AUTH_SECRET=your_random_secret_at_least_32_chars
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Encryption key for connected account secrets (32-byte key, base64 or 64-char hex)
# Example: openssl rand -base64 32
SCHEDULER_ENCRYPTION_KEY=

# ===========================================
# Billing (Stripe)
# ===========================================
# Self-hosted mode: set to true to disable all billing and Stripe integration.
# Every user gets unrestricted access and none of the STRIPE_* variables below
# are needed. Off by default.
# SELF_HOSTED=true

# ===========================================
# Reviewer test account
# ===========================================
# Enables the hard-coded OpenAI reviewer password login (openai@simplepost.social
# / openai). Only set this in review/staging environments — never in production.
# ENABLE_OPENAI_TEST_LOGIN=true

# Price IDs must be recurring monthly prices with USD default and EUR currency options.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_BASIC_PRICE_ID=price_your_basic_monthly_multicurrency_price_id
STRIPE_ADVANCED_PRICE_ID=price_your_advanced_monthly_multicurrency_price_id
STRIPE_PRO_PRICE_ID=price_your_pro_monthly_multicurrency_price_id
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=bpc_your_billing_portal_configuration_id

# Google OAuth (for login AND YouTube)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===========================================
# Social Platform Connections
# ===========================================

# Comma-separated provider IDs that can be connected in this deployment.
# Unset or empty disables every social provider. Use * to enable all.
# Supported IDs: x,youtube,instagram,facebook,tiktok,bluesky,threads,linkedin,pinterest,telegram,forem,farcaster
# NEXT_PUBLIC_ENABLED_SOCIAL_PROVIDERS=x,youtube,forem

# TikTok
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# YouTube (uses same Google credentials as login above)
# YOUTUBE_CLIENT_ID and YOUTUBE_CLIENT_SECRET default to GOOGLE_CLIENT_ID/SECRET
# Only set these if you want separate credentials for YouTube:
# YOUTUBE_CLIENT_ID=your_youtube_client_id
# YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# X (Twitter)
X_CLIENT_ID=your_x_client_id
X_CLIENT_SECRET=your_x_client_secret

# Facebook
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret

# Instagram (uses Instagram Login API)
INSTAGRAM_CLIENT_ID=your_instagram_app_id
INSTAGRAM_CLIENT_SECRET=your_instagram_app_secret

# Bluesky
# Defaults to ${NEXT_PUBLIC_APP_URL}/oauth/client-metadata.json
# BLUESKY_CLIENT_ID=https://yourdomain.com/oauth/client-metadata.json
BLUESKY_CLIENT_SECRET=
BLUESKY_OAUTH_ISSUER=https://bsky.social

# Threads
THREADS_CLIENT_ID=your_threads_app_id
THREADS_CLIENT_SECRET=your_threads_app_secret

# LinkedIn
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Pinterest
PINTEREST_CLIENT_ID=your_pinterest_app_id
PINTEREST_CLIENT_SECRET=your_pinterest_app_secret
# Default board ID for Pinterest posts (can be overridden per-post in UI)
# PINTEREST_BOARD_ID=1234567890123456789

# Telegram (optional - users provide their own bot tokens)
# Only set if you want a fallback bot token:
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Farcaster (direct Snapchain integration; no hosted API provider)
# This must be a dedicated application FID. Its custody key signs only the
# SignedKeyRequest metadata used to sponsor scoped user signers. Never expose
# the custody private key to the browser or NEXT_PUBLIC_* variables.
FARCASTER_APP_FID=
FARCASTER_APP_CUSTODY_PRIVATE_KEY=
# Comma-separated gRPC endpoints, in failover order. Use grpcs:// in production.
FARCASTER_SNAPCHAIN_URLS=grpcs://snapchain-primary.example.com:3383,grpcs://snapchain-secondary.example.com:3383
# Sliding inactivity TTL in seconds. Default 30 days; protocol maximum 90 days.
# FARCASTER_SIGNER_TTL_SECONDS=2592000



# Scheduled dispatch job
# Secret for POST /api/internal/scheduled-posts/dispatch (publishes due posts and refreshes expiring account tokens)
SCHEDULED_POST_DISPATCH_SECRET=change_me

# ===========================================
# Logging (optional)
# ===========================================
# LOG_LEVEL=debug  # debug, info, warn, error
# NODE_ENV=development
# Send error/fatal logs to Telegram. Uses a dedicated logging bot token so it
# does not conflict with user-connected Telegram posting bots.
# LOG_TELEGRAM_BOT_TOKEN=123456:your_logging_bot_token
# LOG_TELEGRAM_CHAT_ID=-1001234567890
# LOG_TELEGRAM_MIN_LEVEL=error
# LOG_TELEGRAM_MAX_PER_MINUTE=10
# LOG_TELEGRAM_DISABLED=false
