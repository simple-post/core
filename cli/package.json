{
  "name": "@simple-post/cli",
  "version": "0.1.0",
  "description": "SimplePost CLI for cross-platform posting",
  "type": "module",
  "files": [
    "bin",
    "dist",
    "README.md",
    "package.json"
  ],
  "bin": {
    "simple-post": "./bin/run.js"
  },
  "scripts": {
    "clean": "rm -rf dist oclif.manifest.json",
    "build": "yarn clean && tsc -p tsconfig.json && node ./scripts/generate-manifest.mjs",
    "compile": "tsc --noEmit -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "yarn build && jest -c jest.config.cjs --runInBand --verbose",
    "prepack": "yarn build"
  },
  "oclif": {
    "bin": "simple-post",
    "dirname": "simple-post",
    "topicSeparator": " ",
    "flexibleTaxonomy": true,
    "topics": {
      "account": {
        "description": "Manage connected accounts.",
        "hidden": true
      }
    },
    "commands": {
      "strategy": "pattern",
      "target": "./dist/cli/src/commands"
    }
  },
  "dependencies": {
    "@oclif/core": "^4.9.0",
    "@simple-post/sdk": "*"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@oclif/test": "^4.1.16",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "jest": "^30.0.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3"
  }
}
