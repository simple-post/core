# SimplePost Server Configuration
SIMPLE_POST_API_KEY=your-secret-api-key-here
PORT=3000

# Public URL the server is reachable at. Returned in upload responses
# and used in media URLs that platforms will fetch. Defaults to
# http://localhost:${PORT} if unset.
SIMPLE_POST_PUBLIC_URL=https://posts.example.com

# Local directory where uploaded files are stored.
SIMPLE_POST_STORAGE_DIR=./data

# Optional S3-compatible storage for direct browser/agent uploads through
# POST /api/v1/upload/presign. The base URL must expose objects publicly so
# social platforms can fetch them. Browser clients also need a bucket CORS
# rule allowing PUT and Content-Type from the exact application origin.
S3_STORAGE_ACCESS_KEY_ID=
S3_STORAGE_SECRET_ACCESS_KEY=
S3_STORAGE_REGION=auto
S3_STORAGE_BUCKET=
S3_STORAGE_BASE_URL=https://files.example.com
S3_STORAGE_ENDPOINT=

# Disabled by default. Set to the exact proxy hop count, subnet, or Express
# trust-proxy value only when this server runs behind a proxy you control.
TRUST_PROXY=false

# Path to a JSON file describing connected accounts. Without this file the
# server starts but rejects /api/v1/posts requests because no account IDs
# resolve. See README for the file format.
SIMPLE_POST_ACCOUNTS_FILE=./accounts.json
