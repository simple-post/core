{
  "name": "@simple-post/core",
  "version": "1.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "sdk",
      "examples",
      "server",
      "scheduler",
      "cli"
    ]
  },
  "scripts": {
    "check": "yarn workspaces foreach --all --parallel run check",
