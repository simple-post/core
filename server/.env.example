# SimplePost Server Configuration
SIMPLE_POST_API_KEY=your-secret-api-key-here
PORT=3000

# Public URL the server is reachable at. Returned in upload responses
# and used in media URLs that platforms will fetch. Defaults to
# http://localhost:${PORT} if unset.
SIMPLE_POST_PUBLIC_URL=https://posts.example.com

# Local directory where uploaded files are stored.
SIMPLE_POST_STORAGE_DIR=./data

# Path to a JSON file describing connected accounts. Without this file the
# server starts but rejects /api/v1/posts requests because no account IDs
# resolve. See README for the file format.
SIMPLE_POST_ACCOUNTS_FILE=./accounts.json
