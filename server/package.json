{
  "name": "@simple-post/server",
  "version": "0.1.0",
  "description": "HTTP server that exposes an API for posting to social media using SimplePost SDK",
  "author": "Vladimir Haltakov <vlad@creafexlab.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup",
    "compile": "tsc --noEmit",
    "check": "tsc --noEmit && eslint . && prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "prepack": "yarn build"
  },
  "dependencies": {
    "@simple-post/sdk": "workspace:*",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
