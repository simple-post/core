# ===========================================
# Database
# ===========================================
DATABASE_URL=postgres://user:password@localhost:5432/simplepost?schema=public

# ===========================================
# Cloudflare R2 (Media Storage)
# ===========================================
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=simple-post-scheduler
R2_PUBLIC_URL=https://files.yourdomain.com

# S3 Storage (for Instagram - media must be at public URLs; any S3-compatible storage)
S3_STORAGE_ACCESS_KEY_ID=your_s3_access_key_id
S3_STORAGE_SECRET_ACCESS_KEY=your_s3_secret_access_key
S3_STORAGE_REGION=auto
S3_STORAGE_BUCKET=simplepost-temp
S3_STORAGE_BASE_URL=https://storage.yourdomain.com
S3_STORAGE_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ===========================================
# Email (Resend)
# ===========================================
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_ADDRESS="Simple Post Scheduler <auth@yourdomain.com>"

# ===========================================
# Authentication (Better Auth)
# ===========================================
BETTER_AUTH_SECRET=your_random_secret_at_least_32_chars
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (for login AND YouTube)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===========================================
# Social Platform Connections
# ===========================================

# TikTok
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# YouTube (uses same Google credentials as login above)
# YOUTUBE_CLIENT_ID and YOUTUBE_CLIENT_SECRET default to GOOGLE_CLIENT_ID/SECRET
# Only set these if you want separate credentials for YouTube:
# YOUTUBE_CLIENT_ID=your_youtube_client_id
# YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# X (Twitter)
X_CLIENT_ID=your_x_client_id
X_CLIENT_SECRET=your_x_client_secret

# Facebook
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret

# Instagram (uses Instagram Login API)
INSTAGRAM_CLIENT_ID=your_instagram_app_id
INSTAGRAM_CLIENT_SECRET=your_instagram_app_secret

# Bluesky
BLUESKY_CLIENT_ID=https://yourdomain.com/.well-known/atproto-client.json
BLUESKY_CLIENT_SECRET=
BLUESKY_OAUTH_ISSUER=https://bsky.social

# Threads
THREADS_CLIENT_ID=your_threads_app_id
THREADS_CLIENT_SECRET=your_threads_app_secret

# LinkedIn
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Pinterest
PINTEREST_CLIENT_ID=your_pinterest_app_id
PINTEREST_CLIENT_SECRET=your_pinterest_app_secret
# Default board ID for Pinterest posts (can be overridden per-post in UI)
# PINTEREST_BOARD_ID=1234567890123456789

# Telegram (optional - users provide their own bot tokens)
# Only set if you want a fallback bot token:
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ===========================================
# Logging (optional)
# ===========================================
# LOG_LEVEL=debug  # debug, info, warn, error
# NODE_ENV=development
