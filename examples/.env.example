# X (OAuth 2.0)
# Set X_CLIENT_ID and at least one of X_ACCESS_TOKEN / X_REFRESH_TOKEN.
# - Access-token mode (X_ACCESS_TOKEN, optionally X_EXPIRES_AT): used as-is, no refresh.
# - Refresh-token mode (X_REFRESH_TOKEN): SDK refreshes on first use. X rotates
#   refresh tokens — persist the new one returned in extraData.refreshedCredentials
#   or the next refresh will fail.
# - Both: SDK uses the access token while valid and refreshes when needed.
# X_CLIENT_SECRET is required only for confidential OAuth 2.0 clients.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_ACCESS_TOKEN=
X_EXPIRES_AT=
X_REFRESH_TOKEN=

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Instagram
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Facebook
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# Bluesky
BLUESKY_ACCESS_TOKEN=
BLUESKY_REFRESH_TOKEN=
BLUESKY_DID=
BLUESKY_PDS_URL=

# Threads
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_MEMBER_ID=

# Pinterest
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

# S3 Temporary Storage
S3_STORAGE_ACCESS_KEY_ID=
S3_STORAGE_SECRET_ACCESS_KEY=
S3_STORAGE_REGION=
S3_STORAGE_BUCKET=
S3_STORAGE_BASE_URL=
S3_STORAGE_ENDPOINT=
FOREM_INSTANCE_URL=https://dev.to
FOREM_API_KEY=
