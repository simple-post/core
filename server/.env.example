# SimplePost Server Configuration
SIMPLE_POST_API_KEY=your-secret-api-key-here
PORT=3000

# Social Media Platform Credentials (same as SDK)
# See the SDK README for detailed instructions on obtaining these credentials

# X (Twitter) App Credentials
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_SECRET=your-x-access-secret

# X (Twitter) User Credentials (OAuth 2.0 PKCE - alternative to app credentials)
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
X_OAUTH_ACCESS_TOKEN=your-x-oauth-access-token
X_OAUTH_REFRESH_TOKEN=your-x-oauth-refresh-token
X_OAUTH_EXPIRES_AT=1234567890

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# YouTube
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REFRESH_TOKEN=your-youtube-refresh-token

# Facebook
FACEBOOK_PAGE_ACCESS_TOKEN=your-facebook-page-access-token
FACEBOOK_PAGE_ID=your-facebook-page-id

# Instagram
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-instagram-business-account-id