{
  "name": "@simple-post/server",
  "version": "0.1.0",
  "description": "HTTP server that exposes an API for posting to social media using SimplePost SDK",
  "author": "Vladimir Haltakov <vlad@creafexlab.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup",
    "compile": "tsc --noEmit",
    "check": "tsc --noEmit && eslint . && prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "stop:pm2": "pm2 stop ecosystem.config.js",
    "restart:pm2": "pm2 restart ecosystem.config.js",
    "logs:pm2": "pm2 logs simple-post-server",
    "monit:pm2": "pm2 monit",
    "docker:build": "docker build -t simple-post-server .",
    "docker:run": "docker run -p 3000:3000 --env-file .env simple-post-server",
    "docker:dev": "docker run -p 3000:3000 --env-file .env -v $(pwd):/app simple-post-server",
    "docker:compose": "docker-compose up -d",
    "docker:compose:build": "docker-compose up -d --build",
    "docker:compose:logs": "docker-compose logs -f",
    "docker:compose:down": "docker-compose down",
    "prepack": "yarn build"
  },
  "dependencies": {
    "@simple-post/sdk": "workspace:*",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "pm2": "^5.4.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
