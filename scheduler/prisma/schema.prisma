// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id
  name              String
  email             String
  emailVerified     Boolean            @default(false)
  image             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt
  sessions          Session[]
  accounts          Account[] // For authentication
  connectedAccounts ConnectedAccount[] // For social media posting
  posts             Post[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  // Store account profile information (username, display name, email, etc.)
  profile               String?

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

// Separate model for connected social media accounts (for posting)
// This is different from the Account model which is used for authentication
model ConnectedAccount {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Platform information
  platform          String // "facebook", "instagram", "tiktok", "youtube", "twitter"
  platformAccountId String // The user's ID on that platform

  // OAuth tokens for API access
  accessToken  String
  refreshToken String?
  tokenType    String?   @default("Bearer")
  expiresAt    DateTime?
  scope        String?

  // Account profile information
  username       String? // @handle or username
  displayName    String? // Full name or display name
  email          String?
  profilePicture String?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  posts Post[]

  @@unique([userId, platform, platformAccountId])
  @@index([userId])
  @@map("connected_account")
}

// Scheduled posts
model Post {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  message      String
  scheduledFor DateTime
  status       String    @default("scheduled") // "scheduled", "published", "failed"
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Account-specific options stored as JSON
  accountOptions Json?

  // Relations
  accounts ConnectedAccount[]
  media    MediaFile[]

  @@index([userId, status])
  @@index([userId, scheduledFor])
  @@map("post")
}

// Media files stored in Cloudflare R2
model MediaFile {
  id           String   @id @default(cuid())
  postId       String
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  url          String // R2 URL
  thumbnailUrl String? // R2 thumbnail URL
  type         String // "image" or "video"
  filename     String
  size         Int
  createdAt    DateTime @default(now())

  @@index([postId])
  @@map("media_file")
}
