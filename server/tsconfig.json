{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@simple-post/sdk": ["../sdk/src/index.ts"],
      "@simple-post/sdk/media-types": ["../sdk/src/media-types.ts"],
      "@simple-post/sdk/platform-names": ["../sdk/src/platform-names.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist/**/*", "node_modules/**/*"]
}
