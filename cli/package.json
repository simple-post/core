{
  "name": "@simple-post/cli",
  "version": "1.1.0",
  "description": "Post to X, Telegram, YouTube, Instagram, and more from your terminal.",
  "author": "Vladimir Haltakov <vlad@creafexlab.com>",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/simple-post/core/tree/main/cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simple-post/core.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/simple-post/core/issues"
  },
  "keywords": [
    "cli",
    "social-media",
    "posting",
    "scheduler",
    "x",
    "twitter",
    "telegram",
    "youtube",
    "instagram",
    "facebook",
    "tiktok",
    "bluesky",
    "threads",
    "linkedin",
    "pinterest",
    "lemmy"
  ],
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json",
    "README.md"
  ],
  "bin": {
    "simplepost": "./bin/run.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "clean": "rm -rf dist oclif.manifest.json",
    "build": "yarn clean && yarn workspace @simple-post/sdk build && tsc -p tsconfig.build.json && node ./scripts/generate-manifest.mjs",
    "compile": "tsc --noEmit -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json && eslint . && prettier --check .",
    "test": "yarn build && jest -c jest.config.cjs --runInBand --verbose",
    "prepack": "yarn build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "oclif": {
    "bin": "simplepost",
    "dirname": "simplepost",
    "topicSeparator": " ",
    "flexibleTaxonomy": true,
    "topics": {
      "account": {
        "description": "List, add, and remove connected accounts."
      }
    },
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "theme": {
      "bin": "#c6f432",
      "command": "#c6f432",
      "commandSummary": "#b8b8b8",
      "dollarSign": "#555555",
      "flag": "#c6f432",
      "flagDefaultValue": "#555555",
      "flagOptions": "#858585",
      "flagSeparator": "#555555",
      "sectionDescription": "#b8b8b8",
      "sectionHeader": "bold",
      "topic": "#c6f432",
      "version": "#555555"
    }
  },
  "dependencies": {
    "@oclif/core": "^4.9.0",
    "@simple-post/sdk": "^1.1.0",
    "selfsigned": "^5.5.0"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@oclif/test": "^4.1.16",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unicorn": "^59.0.1",
    "globals": "^15.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  }
}
