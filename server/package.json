{
  "name": "@simple-post/server",
  "version": "1.0.0",
  "description": "HTTP server that exposes an API for posting to social media using SimplePost SDK",
  "author": "Vladimir Haltakov <vlad@creafexlab.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup",
    "compile": "tsc --noEmit",
    "check": "tsc --noEmit && eslint . && prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "dev": "tsx watch --tsconfig tsconfig.json -r dotenv/config src/index.ts",
    "start": "node dist/index.js",
    "start:pm2": "pm2 start pm2.config.cjs",
    "stop:pm2": "pm2 stop pm2.config.cjs",
    "restart:pm2": "pm2 restart pm2.config.cjs",
    "logs:pm2": "pm2 logs simple-post-server",
    "monit:pm2": "pm2 monit",
    "docker:build": "cd .. && docker build -t simple-post-server -f server/Dockerfile .",
    "docker:run": "docker run -p 3000:3000 --env-file .env simple-post-server",
    "docker:dev": "docker run -p 3000:3000 --env-file .env -v $(pwd):/app simple-post-server",
    "prepack": "yarn build"
  },
  "dependencies": {
    "@simple-post/sdk": "workspace:*",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "multer": "^1.4.5-lts.1",
    "pm2": "^5.4.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
