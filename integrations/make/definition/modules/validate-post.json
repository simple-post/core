{
  "name": "Validate a post",
  "type": "action",
  "label": "Validate a post",
  "description": "Validates a post against selected social accounts without creating it.",
  "communication": {
    "url": "/api/v1/validation",
    "method": "POST",
    "body": "{{parameters}}",
    "response": {
      "output": "{{body}}"
    }
  },
  "mappableParameters": [
    { "name": "message", "label": "Message", "type": "text", "multiline": true },
    {
      "name": "accountIds",
      "label": "Account IDs",
      "type": "array",
      "required": true,
      "spec": { "type": "text", "label": "Account ID" }
    },
    { "name": "media", "label": "Media", "type": "json" },
    { "name": "thread", "label": "Thread", "type": "json" },
    { "name": "accountOverrides", "label": "Account overrides", "type": "json" }
  ],
  "interface": [
    { "name": "summary.isValid", "label": "Is valid", "type": "boolean" },
    { "name": "summary.errors", "label": "Errors", "type": "array" },
    { "name": "summary.warnings", "label": "Warnings", "type": "array" }
  ]
}
