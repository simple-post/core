{
  "name": "@simple-post/sdk",
  "version": "1.1.0",
  "description": "Post to all social platforms with one TypeScript library.",
  "author": "Vladimir Haltakov <vlad@creafexlab.com>",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/simple-post/core/tree/main/sdk",
  "bugs": {
    "url": "https://github.com/simple-post/core/issues"
  },
  "keywords": [
    "social-media",
    "posting",
    "sdk",
    "x",
    "twitter",
    "telegram",
    "youtube",
    "instagram",
    "facebook",
    "tiktok",
    "bluesky",
    "threads",
    "linkedin",
    "pinterest",
    "forem",
    "dev.to",
    "google-business-profile"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js",
      "require": "./dist/validation.cjs"
    },
    "./media-types": {
      "types": "./dist/media-types.d.ts",
      "import": "./dist/media-types.js",
      "require": "./dist/media-types.cjs"
    },
    "./platform-names": {
      "types": "./dist/platform-names.d.ts",
      "import": "./dist/platform-names.js",
      "require": "./dist/platform-names.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simple-post/core.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup",
    "compile": "tsc --noEmit",
    "check": "tsc --noEmit && eslint . && prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "prepack": "yarn build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1084.0",
    "@aws-sdk/lib-storage": "^3.1084.0",
    "@aws-sdk/s3-request-presigner": "^3.1084.0",
    "axios": "^1.18.1",
    "form-data": "^4.0.6",
    "googleapis": "^150.0.1",
    "twitter-api-v2": "^1.23.2",
    "uuid": "^11.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.30.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-unicorn": "^59.0.1",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.4.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  }
}
